# Copy this file to .env and fill in real values before running the server.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/the_young_creatives

# Port the API server listens on
PORT=4000

# Origin allowed to call this API (your frontend dev server / production domain)
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign admin JWT sessions — use a long random string in production
JWT_SECRET=replace-this-with-a-long-random-string

# Optional: used only by `npm run db:seed` to create the first admin login
SEED_ADMIN_EMAIL=admin@theyoungcreatives.studio
SEED_ADMIN_PASSWORD=ChangeMe123!
